---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { getVagas } from '../lib/sanity';
import type { Vaga } from '../lib/sanity';

let vagas: Vaga[] = [];
try {
  vagas = await getVagas();
} catch (e) {
  vagas = [];
}

const tipoColors: Record<string, string> = {
  'Tempo Integral': 'bg-blue-100 text-blue-700',
  'Tempo Parcial': 'bg-purple-100 text-purple-700',
  'Consultoria': 'bg-amber-100 text-amber-700',
  'Voluntariado': 'bg-green-100 text-green-700',
  'Estágio': 'bg-pink-100 text-pink-700',
};
---

<Layout title="Recrutamento | APROCOSO">
  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-center justify-center overflow-hidden bg-slate-950 pt-24 pb-16">
    <div class="absolute inset-0 bg-gradient-to-tr from-slate-950 via-primary/20 to-slate-950"></div>
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/20 rounded-full blur-[120px] pointer-events-none -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-blue-600/10 rounded-full blur-[150px] pointer-events-none translate-y-1/3 -translate-x-1/4"></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] bg-[size:4rem_4rem]"></div>

    <div class="container mx-auto px-4 max-w-6xl relative z-10 text-center">
      <div class="inline-flex items-center gap-2 py-1.5 px-4 rounded-full bg-white/[0.04] border border-white/10 text-slate-300 font-medium mb-6 text-xs tracking-widest uppercase backdrop-blur-md">
        <span class="w-2 h-2 rounded-full bg-blue-500"></span>
        Faça parte da equipa
      </div>
      <h1 class="text-5xl md:text-6xl font-black text-white tracking-tight mb-6">
        Trabalhe <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-200 to-white">Connosco</span>
      </h1>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto font-light leading-relaxed">
        Junte-se à APROCOSO e contribua para a transformação de vidas e comunidades em Moçambique.
      </p>
    </div>
  </section>

  <!-- Vagas -->
  <section class="py-24 bg-light relative">
    <div class="container mx-auto px-4 max-w-6xl">

      {vagas.length > 0 ? (
        <>
          <div class="text-center mb-16">
            <p class="text-gray-500 text-lg">
              <span class="font-bold text-primary">{vagas.length}</span> {vagas.length === 1 ? 'vaga disponível' : 'vagas disponíveis'}
            </p>
          </div>

          <div class="space-y-6">
            {vagas.map((vaga) => {
              const prazo = new Date(vaga.prazoInscricao);
              const hoje = new Date();
              const diasRestantes = Math.ceil((prazo.getTime() - hoje.getTime()) / (1000 * 60 * 60 * 24));
              const urgente = diasRestantes <= 7 && diasRestantes > 0;

              return (
                <a
                  href={`/recrutamento/${vaga.slug.current}`}
                  class="group flex flex-col md:flex-row md:items-center gap-6 bg-white rounded-2xl p-6 md:p-8 border border-gray-100 shadow-sm hover:shadow-xl hover:-translate-y-1 hover:border-primary/20 transition-all duration-300"
                >
                  <div class="w-14 h-14 shrink-0 bg-primary/5 group-hover:bg-primary rounded-2xl flex items-center justify-center transition-colors duration-300">
                    <Icon name="target" class="w-7 h-7 text-primary group-hover:text-white transition-colors duration-300" />
                  </div>

                  <div class="flex-grow min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                      <span class={`text-xs font-bold px-3 py-1 rounded-full ${tipoColors[vaga.tipoContrato] ?? 'bg-gray-100 text-gray-600'}`}>
                        {vaga.tipoContrato}
                      </span>
                      {urgente && (
                        <span class="text-xs font-bold px-3 py-1 rounded-full bg-red-100 text-red-600 animate-pulse">
                          ⏰ Encerra em breve!
                        </span>
                      )}
                    </div>
                    <h2 class="text-xl font-bold text-primary-dark group-hover:text-primary transition-colors truncate">
                      {vaga.titulo}
                    </h2>
                    <div class="flex flex-wrap items-center gap-4 mt-2 text-sm text-gray-500">
                      <span class="flex items-center gap-1.5">
                        <Icon name="map-pin" class="w-4 h-4 text-gray-400" />
                        {vaga.localizacao}
                      </span>
                      <span class="flex items-center gap-1.5">
                        <Icon name="book" class="w-4 h-4 text-gray-400" />
                        {vaga.departamento}
                      </span>
                      <span class="flex items-center gap-1.5">
                        <Icon name="eye" class="w-4 h-4 text-gray-400" />
                        Prazo: {prazo.toLocaleDateString('pt-PT', { day: 'numeric', month: 'long', year: 'numeric' })}
                      </span>
                    </div>
                  </div>

                  <div class="shrink-0 flex items-center gap-2 text-primary font-semibold text-sm group-hover:gap-3 transition-all duration-300">
                    Ver Vaga
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                    </svg>
                  </div>
                </a>
              );
            })}
          </div>
        </>
      ) : (
        <div class="text-center py-24 bg-white rounded-3xl border border-dashed border-gray-200 max-w-2xl mx-auto">
          <div class="w-20 h-20 bg-primary/5 rounded-full flex items-center justify-center mx-auto mb-6">
            <Icon name="newspaper" class="w-10 h-10 text-primary/40" />
          </div>
          <h3 class="text-2xl font-bold text-primary-dark mb-3">Sem vagas abertas de momento</h3>
          <p class="text-gray-500 text-lg max-w-md mx-auto leading-relaxed">
            Não há vagas disponíveis neste momento. Siga-nos nas redes sociais para ser o primeiro a saber das nossas oportunidades!
          </p>
          <a
            href="/#contactos"
            class="mt-8 inline-flex items-center gap-2 bg-primary text-white px-6 py-3 rounded-xl font-bold hover:bg-primary-dark transition"
          >
            Candidatura Espontânea
          </a>
        </div>
      )}

      <!-- Candidatura Espontânea -->
      <div class="mt-20 bg-primary-dark rounded-3xl p-10 md:p-16 text-white text-center relative overflow-hidden">
        <div class="absolute -right-16 -top-16 w-64 h-64 bg-primary rounded-full opacity-20 blur-3xl"></div>
        <div class="absolute -left-16 -bottom-16 w-64 h-64 bg-blue-500 rounded-full opacity-10 blur-3xl"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-bold mb-4">Não encontrou a sua vaga?</h2>
          <p class="text-blue-100 text-lg mb-8 max-w-xl mx-auto">
            Envie-nos uma candidatura espontânea. Estamos sempre à procura de pessoas comprometidas com a nossa missão.
          </p>
          <a
            href="mailto:info.aprocoso@gmail.com?subject=Candidatura Espontânea – APROCOSO"
            class="inline-flex items-center gap-2 bg-white text-primary-dark px-8 py-4 rounded-xl font-bold hover:bg-blue-50 transition shadow-lg"
          >
            <Icon name="mail" class="w-5 h-5" />
            Enviar Candidatura Espontânea
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>
