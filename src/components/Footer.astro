---
import Icon from './Icon.astro';
---

<footer class="bg-primary-dark text-white pt-16 pb-8" id="contactos">
  <!-- Parceiros -->
  <div class="container mx-auto px-4 max-w-7xl mb-16">
    <div class="bg-white/[0.02] border border-white/5 rounded-3xl p-8 md:p-10 backdrop-blur-sm">
      <h4 class="text-center text-xs font-bold tracking-widest uppercase text-primary-light mb-8 flex items-center justify-center gap-4">
        <span class="h-px w-8 bg-primary-light/30"></span>
        Nossa Rede de Parceiros
        <span class="h-px w-8 bg-primary-light/30"></span>
      </h4>
      <div class="flex flex-wrap justify-center items-stretch gap-4">
        {[
          "Instituições Governamentais",
          "Organizações da Sociedade Civil",
          "Organizações Humanitárias",
          "Agências das Nações Unidas",
          "Doadores Nacionais e Internacionais",
          "Líderes Comunitários",
          "Redes de Proteção Comunitária"
        ].map((partner) => (
          <div class="flex flex-col items-center justify-center px-6 py-5 bg-white/5 hover:bg-white/10 border border-white/5 rounded-2xl transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:shadow-primary/5 group min-w-[200px] flex-grow md:flex-grow-0">
            <span class="text-gray-400 group-hover:text-white text-sm font-semibold transition-colors text-center leading-snug">
              {partner}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div
    class="container mx-auto px-4 max-w-6xl grid grid-cols-1 md:grid-cols-3 gap-12 mb-12"
  >
    <div>
      <h3 class="text-2xl font-bold mb-4">APROCOSO</h3>
      <p class="mb-4 text-gray-300">
        Associação Progressista e Coesão Solidária
      </p>
      <p class="text-sm text-primary-light italic">
        "Promovendo Proteção, Inclusão e Resiliência para Transformar Vidas e
        Fortalecer Comunidades."
      </p>
    </div>

    <div>
      <h4
        class="text-xl font-semibold mb-6 border-b border-primary-light/30 pb-2"
      >
        Contactos
      </h4>
      <ul class="space-y-4 text-gray-300">
        <li class="flex items-start gap-3">
          <Icon name="map-pin" class="w-5 h-5 text-primary-light shrink-0" />
          Sede: Pemba, Cabo Delgado, Moçambique
        </li>
        <li class="flex items-center gap-3">
          <Icon name="mail" class="w-5 h-5 text-primary-light shrink-0" />
          <a
            href="mailto:contato@aprocoso.org.mz"
            class="hover:text-white transition">contato@aprocoso.org.mz</a
          >
        </li>
        <li class="flex items-center gap-3">
          <Icon name="phone" class="w-5 h-5 text-primary-light shrink-0" />
          <a href="tel:+258858127353" class="hover:text-white transition"
            >+258 85 812 7353</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4
        class="text-xl font-semibold mb-6 border-b border-primary-light/30 pb-2"
      >
        Redes Sociais
      </h4>
      <div class="flex flex-wrap gap-4">
        <a
          href="https://web.facebook.com/profile.php?id=61567874031426"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary/50 p-3 rounded-full hover:bg-primary transition"
          aria-label="Facebook"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"
            ><path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.linkedin.com/company/aprocoso-%E2%80%93-associa%C3%A7%C3%A3o-progressista-e-coes%C3%A3o-solid%C3%A1ria?trk=public_post_feed-actor-name"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary/50 p-3 rounded-full hover:bg-primary transition"
          aria-label="LinkedIn"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"
            ><path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.instagram.com/aprocoso/"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary/50 p-3 rounded-full hover:bg-primary transition"
          aria-label="Instagram"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"
            ><path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
            ></path></svg
          >
        </a>
        <a
          href="https://whatsapp.com/channel/0029VbCjHiDEquiPR4LVNX1E"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-primary/50 p-3 rounded-full hover:bg-primary transition"
          aria-label="WhatsApp"
        >
          <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"
            ><path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path></svg
          >
        </a>
      </div>
    </div>
  </div>

  <div
    class="text-center text-sm text-gray-400 border-t border-primary/50 pt-8 mt-8"
  >
    &copy; {new Date().getFullYear()} APROCOSO. Todos os direitos reservados. Construído
    com <a href="https://www.vizualz.co.mz/">Visualz</a>.
  </div>
</footer>
